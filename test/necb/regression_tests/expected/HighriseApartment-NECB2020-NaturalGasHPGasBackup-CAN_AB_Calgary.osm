  SET {9bf90de4-6286-4517-9c95-3e8126be5785} = 29.4, !- Program Line 8
  SET {6cb6b3ba-2d64-4ad9-a44f-81cb4690382b} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {4dcd3ff7-4c2d-4333-8b7e-bf9cbe76bb67}<23.9 && {4dcd3ff7-4c2d-4333-8b7e-bf9cbe76bb67}>1.7, !- Program Line 10
  SET {9bf90de4-6286-4517-9c95-3e8126be5785} = 29.4, !- Program Line 11
