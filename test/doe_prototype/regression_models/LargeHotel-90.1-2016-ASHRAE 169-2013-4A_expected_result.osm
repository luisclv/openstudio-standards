  {6d3e6974-b5d4-40b3-807f-fb2a1a09c12c}, !- Handle
  ems_VAV_WITH_REHEAT_OptimumStartProg0,  !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {80929847-d9bd-499f-8a1d-ae08b4717324}<23.9 && {80929847-d9bd-499f-8a1d-ae08b4717324}>1.7, !- Program Line 1
  SET {2f6c1a98-9a95-4583-a275-6667d4483bf4} = 29.4, !- Program Line 2
  SET {4455dc43-4f7b-47b7-9ae2-a60e4f7331e9} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {80929847-d9bd-499f-8a1d-ae08b4717324}<23.9 && {80929847-d9bd-499f-8a1d-ae08b4717324}>1.7, !- Program Line 4
  SET {2f6c1a98-9a95-4583-a275-6667d4483bf4} = 29.4, !- Program Line 5
  SET {4455dc43-4f7b-47b7-9ae2-a60e4f7331e9} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {80929847-d9bd-499f-8a1d-ae08b4717324}<23.9 && {80929847-d9bd-499f-8a1d-ae08b4717324}>1.7, !- Program Line 7
  SET {2f6c1a98-9a95-4583-a275-6667d4483bf4} = 29.4, !- Program Line 8
  SET {4455dc43-4f7b-47b7-9ae2-a60e4f7331e9} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {80929847-d9bd-499f-8a1d-ae08b4717324}<23.9 && {80929847-d9bd-499f-8a1d-ae08b4717324}>1.7, !- Program Line 10
  SET {2f6c1a98-9a95-4583-a275-6667d4483bf4} = 29.4, !- Program Line 11
  SET {4455dc43-4f7b-47b7-9ae2-a60e4f7331e9} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {2f6c1a98-9a95-4583-a275-6667d4483bf4} = NULL, !- Program Line 14
  SET {4455dc43-4f7b-47b7-9ae2-a60e4f7331e9} = NULL, !- Program Line 15
