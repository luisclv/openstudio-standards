  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}<23.9 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}>1.7, !- Program Line 4
  SET {3a8923e7-8600-48cf-bd6c-94f1f7b6ca50} = 29.4, !- Program Line 5
  SET {22c64f93-763f-4de8-87f2-fbc5d5530cfe} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}<23.9 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}>1.7, !- Program Line 7
  SET {3a8923e7-8600-48cf-bd6c-94f1f7b6ca50} = 29.4, !- Program Line 8
  SET {22c64f93-763f-4de8-87f2-fbc5d5530cfe} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}<23.9 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}>1.7, !- Program Line 10
  SET {3a8923e7-8600-48cf-bd6c-94f1f7b6ca50} = 29.4, !- Program Line 11
  SET {22c64f93-763f-4de8-87f2-fbc5d5530cfe} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
