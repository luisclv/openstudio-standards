  SET {987f41f2-d9e0-438d-b1f1-61b7b6876809} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}<23.9 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}>1.7, !- Program Line 4
  SET {17eec775-3c1f-4d60-962f-7c55152652aa} = 29.4, !- Program Line 5
  SET {987f41f2-d9e0-438d-b1f1-61b7b6876809} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}<23.9 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}>1.7, !- Program Line 7
  SET {17eec775-3c1f-4d60-962f-7c55152652aa} = 29.4, !- Program Line 8
  SET {987f41f2-d9e0-438d-b1f1-61b7b6876809} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}<23.9 && {af1852a3-b306-445b-ae3c-2f8f038eb1fb}>1.7, !- Program Line 10
  SET {17eec775-3c1f-4d60-962f-7c55152652aa} = 29.4, !- Program Line 11
  SET {987f41f2-d9e0-438d-b1f1-61b7b6876809} = 15.6, !- Program Line 12
