  ems_Aux_Gym_ZN_1_FLR_1_ZN_PSZ_AC_2_6_OptimumStartProg0, !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}<23.9 && {ea029cea-1abf-470b-be06-c6a4ef4f04ca}>1.7, !- Program Line 1
