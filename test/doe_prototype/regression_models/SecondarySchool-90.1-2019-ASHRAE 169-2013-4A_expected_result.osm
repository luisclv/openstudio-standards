OS:EnergyManagementSystem:Program,
  {9d55387a-00fb-4042-aa19-b2da44016372}, !- Handle
  ems_VAV_POD_2_OptimumStartProg0,        !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}<23.9 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}>1.7, !- Program Line 1
  SET {3a61a3fc-665e-405c-8a89-8fca2de1719f} = 29.4, !- Program Line 2
  SET {ecdefd50-d0ea-4e84-a477-6f01a1c857b0} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}<23.9 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}>1.7, !- Program Line 4
  SET {3a61a3fc-665e-405c-8a89-8fca2de1719f} = 29.4, !- Program Line 5
  SET {ecdefd50-d0ea-4e84-a477-6f01a1c857b0} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}<23.9 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}>1.7, !- Program Line 7
  SET {3a61a3fc-665e-405c-8a89-8fca2de1719f} = 29.4, !- Program Line 8
  SET {ecdefd50-d0ea-4e84-a477-6f01a1c857b0} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}<23.9 && {1fb6dde5-6de9-4944-bcc7-a26443e28e96}>1.7, !- Program Line 10
  SET {3a61a3fc-665e-405c-8a89-8fca2de1719f} = 29.4, !- Program Line 11
  SET {ecdefd50-d0ea-4e84-a477-6f01a1c857b0} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {3a61a3fc-665e-405c-8a89-8fca2de1719f} = NULL, !- Program Line 14
  SET {ecdefd50-d0ea-4e84-a477-6f01a1c857b0} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

