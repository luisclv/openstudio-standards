  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {73ef301b-3031-4765-beff-5c895465e550}<23.9 && {73ef301b-3031-4765-beff-5c895465e550}>1.7, !- Program Line 4
  SET {32a7310f-a70f-4b55-b6ac-76b3bf85db6b} = 29.4, !- Program Line 5
  SET {d7df3fea-a250-469f-875e-09190ca444bd} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {73ef301b-3031-4765-beff-5c895465e550}<23.9 && {73ef301b-3031-4765-beff-5c895465e550}>1.7, !- Program Line 7
  SET {32a7310f-a70f-4b55-b6ac-76b3bf85db6b} = 29.4, !- Program Line 8
  SET {d7df3fea-a250-469f-875e-09190ca444bd} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {73ef301b-3031-4765-beff-5c895465e550}<23.9 && {73ef301b-3031-4765-beff-5c895465e550}>1.7, !- Program Line 10
  SET {32a7310f-a70f-4b55-b6ac-76b3bf85db6b} = 29.4, !- Program Line 11
  SET {d7df3fea-a250-469f-875e-09190ca444bd} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
