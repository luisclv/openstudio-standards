OS:EnergyManagementSystem:Program,
  {ac58d2e8-f15b-4f96-a496-d9d91e451d84}, !- Handle
  ems_VAV_POD_3_OptimumStartProg0,        !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}<23.9 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}>1.7, !- Program Line 1
  SET {9f02ba7a-d73e-4429-ae1e-7103de363ddb} = 29.4, !- Program Line 2
  SET {cecba9d3-563f-4cb9-a90d-f5cf4a1f3f75} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}<23.9 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}>1.7, !- Program Line 4
  SET {9f02ba7a-d73e-4429-ae1e-7103de363ddb} = 29.4, !- Program Line 5
  SET {cecba9d3-563f-4cb9-a90d-f5cf4a1f3f75} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}<23.9 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}>1.7, !- Program Line 7
  SET {9f02ba7a-d73e-4429-ae1e-7103de363ddb} = 29.4, !- Program Line 8
  SET {cecba9d3-563f-4cb9-a90d-f5cf4a1f3f75} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}<23.9 && {ce4b6cbc-be00-4490-a9de-374a3b53a560}>1.7, !- Program Line 10
  SET {9f02ba7a-d73e-4429-ae1e-7103de363ddb} = 29.4, !- Program Line 11
  SET {cecba9d3-563f-4cb9-a90d-f5cf4a1f3f75} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {9f02ba7a-d73e-4429-ae1e-7103de363ddb} = NULL, !- Program Line 14
  SET {cecba9d3-563f-4cb9-a90d-f5cf4a1f3f75} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

