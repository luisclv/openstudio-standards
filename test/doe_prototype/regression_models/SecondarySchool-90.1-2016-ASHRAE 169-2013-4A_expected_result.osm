  SET {26f3e23d-78c3-49e5-8826-93ea9daa3c99} = 29.4, !- Program Line 8
  SET {c72c6407-c1ef-49a6-8797-9b0e5d0ee653} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {31bce211-169c-4acf-bcad-e49b2136cd52}<23.9 && {31bce211-169c-4acf-bcad-e49b2136cd52}>1.7, !- Program Line 10
  SET {26f3e23d-78c3-49e5-8826-93ea9daa3c99} = 29.4, !- Program Line 11
  SET {c72c6407-c1ef-49a6-8797-9b0e5d0ee653} = 15.6, !- Program Line 12
