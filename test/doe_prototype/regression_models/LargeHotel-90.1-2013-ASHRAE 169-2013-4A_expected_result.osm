OS:EnergyManagementSystem:Program,
  {5cf63b0b-b031-410b-bc18-f8c0b3ff8b5f}, !- Handle
  ems_VAV_WITH_REHEAT_OptimumStartProg0,  !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {5819173a-6dae-4de8-ae32-36e2d1d552de}<23.9 && {5819173a-6dae-4de8-ae32-36e2d1d552de}>1.7, !- Program Line 1
  SET {b709a9ef-0aa7-47cb-afe0-15f7d563d40d} = 29.4, !- Program Line 2
  SET {fb1e791b-2e8d-427f-ac3a-49647bf96dce} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {5819173a-6dae-4de8-ae32-36e2d1d552de}<23.9 && {5819173a-6dae-4de8-ae32-36e2d1d552de}>1.7, !- Program Line 4
  SET {b709a9ef-0aa7-47cb-afe0-15f7d563d40d} = 29.4, !- Program Line 5
  SET {fb1e791b-2e8d-427f-ac3a-49647bf96dce} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {5819173a-6dae-4de8-ae32-36e2d1d552de}<23.9 && {5819173a-6dae-4de8-ae32-36e2d1d552de}>1.7, !- Program Line 7
  SET {b709a9ef-0aa7-47cb-afe0-15f7d563d40d} = 29.4, !- Program Line 8
  SET {fb1e791b-2e8d-427f-ac3a-49647bf96dce} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {5819173a-6dae-4de8-ae32-36e2d1d552de}<23.9 && {5819173a-6dae-4de8-ae32-36e2d1d552de}>1.7, !- Program Line 10
  SET {b709a9ef-0aa7-47cb-afe0-15f7d563d40d} = 29.4, !- Program Line 11
  SET {fb1e791b-2e8d-427f-ac3a-49647bf96dce} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {b709a9ef-0aa7-47cb-afe0-15f7d563d40d} = NULL, !- Program Line 14
  SET {fb1e791b-2e8d-427f-ac3a-49647bf96dce} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

