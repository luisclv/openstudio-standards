OS:EnergyManagementSystem:Program,
  {73e5b165-2634-4a0e-bff9-66cb5f2afda9}, !- Handle
  ems_VAV_POD_3_OptimumStartProg0,        !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}<23.9 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}>1.7, !- Program Line 1
  SET {32fe80ec-d25c-4373-b925-415a4f900dcd} = 29.4, !- Program Line 2
  SET {236ac18d-8ee7-42f5-83d9-b99dc639f962} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}<23.9 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}>1.7, !- Program Line 4
  SET {32fe80ec-d25c-4373-b925-415a4f900dcd} = 29.4, !- Program Line 5
  SET {236ac18d-8ee7-42f5-83d9-b99dc639f962} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}<23.9 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}>1.7, !- Program Line 7
  SET {32fe80ec-d25c-4373-b925-415a4f900dcd} = 29.4, !- Program Line 8
  SET {236ac18d-8ee7-42f5-83d9-b99dc639f962} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}<23.9 && {051c7cda-5cfb-499c-9b21-c1f7412fa669}>1.7, !- Program Line 10
  SET {32fe80ec-d25c-4373-b925-415a4f900dcd} = 29.4, !- Program Line 11
  SET {236ac18d-8ee7-42f5-83d9-b99dc639f962} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {32fe80ec-d25c-4373-b925-415a4f900dcd} = NULL, !- Program Line 14
  SET {236ac18d-8ee7-42f5-83d9-b99dc639f962} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

