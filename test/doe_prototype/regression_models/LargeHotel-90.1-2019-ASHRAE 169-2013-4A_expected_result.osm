OS:EnergyManagementSystem:Program,
  {37653a93-5716-47f0-8eb0-8a370ba8d0e8}, !- Handle
  ems_VAV_WITH_REHEAT_OptimumStartProg0,  !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}<23.9 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}>1.7, !- Program Line 1
  SET {4691f3a7-9c50-4fee-ac00-3bfab198e8dd} = 29.4, !- Program Line 2
  SET {903d4e94-a6ce-471e-b562-98dbd73c57a7} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}<23.9 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}>1.7, !- Program Line 4
  SET {4691f3a7-9c50-4fee-ac00-3bfab198e8dd} = 29.4, !- Program Line 5
  SET {903d4e94-a6ce-471e-b562-98dbd73c57a7} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}<23.9 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}>1.7, !- Program Line 7
  SET {4691f3a7-9c50-4fee-ac00-3bfab198e8dd} = 29.4, !- Program Line 8
  SET {903d4e94-a6ce-471e-b562-98dbd73c57a7} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}<23.9 && {d0d71baa-0d17-4438-8d0f-f10d242394fb}>1.7, !- Program Line 10
  SET {4691f3a7-9c50-4fee-ac00-3bfab198e8dd} = 29.4, !- Program Line 11
  SET {903d4e94-a6ce-471e-b562-98dbd73c57a7} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {4691f3a7-9c50-4fee-ac00-3bfab198e8dd} = NULL, !- Program Line 14
  SET {903d4e94-a6ce-471e-b562-98dbd73c57a7} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

