OS:EnergyManagementSystem:Program,
  {390ba66d-a499-4883-ada3-672e5fed06b8}, !- Handle
  ems_VAV_PATRMS_OptimumStartProg0,       !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {749a72c0-3115-4180-b227-7f568416d869}<23.9 && {749a72c0-3115-4180-b227-7f568416d869}>1.7, !- Program Line 1
  SET {ea4a6dc3-fad8-4522-a409-638e830ce8ce} = 29.4, !- Program Line 2
  SET {e6cb0194-af79-4bd8-923e-3df4230586ac} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {749a72c0-3115-4180-b227-7f568416d869}<23.9 && {749a72c0-3115-4180-b227-7f568416d869}>1.7, !- Program Line 4
  SET {ea4a6dc3-fad8-4522-a409-638e830ce8ce} = 29.4, !- Program Line 5
  SET {e6cb0194-af79-4bd8-923e-3df4230586ac} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {749a72c0-3115-4180-b227-7f568416d869}<23.9 && {749a72c0-3115-4180-b227-7f568416d869}>1.7, !- Program Line 7
  SET {ea4a6dc3-fad8-4522-a409-638e830ce8ce} = 29.4, !- Program Line 8
  SET {e6cb0194-af79-4bd8-923e-3df4230586ac} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {749a72c0-3115-4180-b227-7f568416d869}<23.9 && {749a72c0-3115-4180-b227-7f568416d869}>1.7, !- Program Line 10
  SET {ea4a6dc3-fad8-4522-a409-638e830ce8ce} = 29.4, !- Program Line 11
  SET {e6cb0194-af79-4bd8-923e-3df4230586ac} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {ea4a6dc3-fad8-4522-a409-638e830ce8ce} = NULL, !- Program Line 14
  SET {e6cb0194-af79-4bd8-923e-3df4230586ac} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

