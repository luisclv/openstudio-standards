OS:EnergyManagementSystem:Program,
  {9a976f16-b6ee-4ebf-9a14-482e85a12cc8}, !- Handle
  ems_CAV_KITCHEN_OptimumStartProg0,      !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {df8b04ad-4e44-4941-a1a6-e535f9730366}<23.9 && {df8b04ad-4e44-4941-a1a6-e535f9730366}>1.7, !- Program Line 1
  SET {d7ff8366-5880-456b-abd3-a0874af0b078} = 29.4, !- Program Line 2
  SET {bcf03727-86da-4638-b0c1-35688248a971} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {df8b04ad-4e44-4941-a1a6-e535f9730366}<23.9 && {df8b04ad-4e44-4941-a1a6-e535f9730366}>1.7, !- Program Line 4
  SET {d7ff8366-5880-456b-abd3-a0874af0b078} = 29.4, !- Program Line 5
  SET {bcf03727-86da-4638-b0c1-35688248a971} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {df8b04ad-4e44-4941-a1a6-e535f9730366}<23.9 && {df8b04ad-4e44-4941-a1a6-e535f9730366}>1.7, !- Program Line 7
  SET {d7ff8366-5880-456b-abd3-a0874af0b078} = 29.4, !- Program Line 8
  SET {bcf03727-86da-4638-b0c1-35688248a971} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {df8b04ad-4e44-4941-a1a6-e535f9730366}<23.9 && {df8b04ad-4e44-4941-a1a6-e535f9730366}>1.7, !- Program Line 10
  SET {d7ff8366-5880-456b-abd3-a0874af0b078} = 29.4, !- Program Line 11
  SET {bcf03727-86da-4638-b0c1-35688248a971} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {d7ff8366-5880-456b-abd3-a0874af0b078} = NULL, !- Program Line 14
  SET {bcf03727-86da-4638-b0c1-35688248a971} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

