OS:EnergyManagementSystem:Program,
  {4f1092a4-af53-4fb4-a1d3-c41bd3e36d0f}, !- Handle
  FrontEntry_HeaterControl,               !- Name
  SET OAT_F = (OAT_F*1.8)+32,             !- Program Line 1
  IF OAT_F > 45,                          !- Program Line 2
  SET FrontEntry_Coil = 0,                !- Program Line 3
  SET FrontEntry_Fan = 0,                 !- Program Line 4
  ELSE,                                   !- Program Line 5
  SET FrontEntry_Coil = 1,                !- Program Line 6
  SET FrontEntry_Fan = 1,                 !- Program Line 7
  ENDIF;                                  !- Program Line 8

