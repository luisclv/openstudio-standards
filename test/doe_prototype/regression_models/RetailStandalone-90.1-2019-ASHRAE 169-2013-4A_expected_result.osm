  SET ems_Point_Of_Sale_LSr_IP=0.093*ems_Point_Of_Sale_LSr/150.81, !- Program Line 1
  IF (Business_Sensor <= 0) && (ems_Point_Of_Sale_LSr_IP >= 0.02), !- Program Line 2
  SET ems_Point_Of_Sale_Light1_Actuator = 0.02*150.81/0.09290304, !- Program Line 3
  ELSE,                                   !- Program Line 4
  SET ems_Point_Of_Sale_Light1_Actuator = NULL, !- Program Line 5
  ENDIF;                                  !- Program Line 6

