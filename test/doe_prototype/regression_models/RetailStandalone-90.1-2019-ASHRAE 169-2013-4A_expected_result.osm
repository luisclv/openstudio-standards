  ems_Core_Retail_ZN_PSZ_AC_OptimumStartProg0, !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}<23.9 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}>1.7, !- Program Line 1
  SET {8857d317-3e6f-4227-a67e-f4ec108f150a} = 29.4, !- Program Line 2
  SET {b98ea90a-7f61-45d8-9e87-e4ffeaa02ce9} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}<23.9 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}>1.7, !- Program Line 4
  SET {8857d317-3e6f-4227-a67e-f4ec108f150a} = 29.4, !- Program Line 5
  SET {b98ea90a-7f61-45d8-9e87-e4ffeaa02ce9} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}<23.9 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}>1.7, !- Program Line 7
  SET {8857d317-3e6f-4227-a67e-f4ec108f150a} = 29.4, !- Program Line 8
  SET {b98ea90a-7f61-45d8-9e87-e4ffeaa02ce9} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}<23.9 && {a8d5bdf4-3b04-4492-8622-1c6935a952ed}>1.7, !- Program Line 10
  SET {8857d317-3e6f-4227-a67e-f4ec108f150a} = 29.4, !- Program Line 11
  SET {b98ea90a-7f61-45d8-9e87-e4ffeaa02ce9} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {8857d317-3e6f-4227-a67e-f4ec108f150a} = NULL, !- Program Line 14
  SET {b98ea90a-7f61-45d8-9e87-e4ffeaa02ce9} = NULL, !- Program Line 15
