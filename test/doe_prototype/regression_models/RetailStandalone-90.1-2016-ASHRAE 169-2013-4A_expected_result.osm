OS:EnergyManagementSystem:Program,
  {bb8247c7-5aac-4b53-9814-43aba16eb805}, !- Handle
  ems_Core_Retail_ZN_PSZ_AC_OptimumStartProg0, !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {ea7ab091-8e97-4423-a892-4b6904300300}<23.9 && {ea7ab091-8e97-4423-a892-4b6904300300}>1.7, !- Program Line 1
  SET {5e25af1e-9516-45ab-ad45-f3ea2061ceef} = 29.4, !- Program Line 2
  SET {57e532f9-a01b-471f-ac2f-0e0a62923642} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {ea7ab091-8e97-4423-a892-4b6904300300}<23.9 && {ea7ab091-8e97-4423-a892-4b6904300300}>1.7, !- Program Line 4
  SET {5e25af1e-9516-45ab-ad45-f3ea2061ceef} = 29.4, !- Program Line 5
  SET {57e532f9-a01b-471f-ac2f-0e0a62923642} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {ea7ab091-8e97-4423-a892-4b6904300300}<23.9 && {ea7ab091-8e97-4423-a892-4b6904300300}>1.7, !- Program Line 7
  SET {5e25af1e-9516-45ab-ad45-f3ea2061ceef} = 29.4, !- Program Line 8
  SET {57e532f9-a01b-471f-ac2f-0e0a62923642} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {ea7ab091-8e97-4423-a892-4b6904300300}<23.9 && {ea7ab091-8e97-4423-a892-4b6904300300}>1.7, !- Program Line 10
  SET {5e25af1e-9516-45ab-ad45-f3ea2061ceef} = 29.4, !- Program Line 11
  SET {57e532f9-a01b-471f-ac2f-0e0a62923642} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {5e25af1e-9516-45ab-ad45-f3ea2061ceef} = NULL, !- Program Line 14
  SET {57e532f9-a01b-471f-ac2f-0e0a62923642} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

