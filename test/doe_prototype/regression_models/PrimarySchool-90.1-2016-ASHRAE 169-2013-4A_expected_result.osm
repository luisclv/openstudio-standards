OS:EnergyManagementSystem:Program,
  {685f4f87-7843-491e-b3fd-8b5402192518}, !- Handle
  SET_ems_Bath_ZN_1_FLR_1_Light_EMS_Program, !- Name
  SET ems_Bath_ZN_1_FLR_1_LSr_IP=0.093*ems_Bath_ZN_1_FLR_1_LSr/190.0, !- Program Line 1
  IF (Business_Sensor <= 0) && (ems_Bath_ZN_1_FLR_1_LSr_IP >= 0.02), !- Program Line 2
  SET ems_Bath_ZN_1_FLR_1_Light1_Actuator = 0.02*190.0/0.09290304, !- Program Line 3
  ELSE,                                   !- Program Line 4
  SET ems_Bath_ZN_1_FLR_1_Light1_Actuator = NULL, !- Program Line 5
  ENDIF;                                  !- Program Line 6

