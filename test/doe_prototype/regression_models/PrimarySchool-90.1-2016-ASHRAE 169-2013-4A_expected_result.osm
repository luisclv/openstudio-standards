OS:EnergyManagementSystem:Program,
  {48de037d-e609-4e4c-aaf0-b7d7130b5b08}, !- Handle
  ems_PVAV_OTHER_OptimumStartProg0,       !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {f5eab967-f824-415d-b91a-a289bde6d8ea}<23.9 && {f5eab967-f824-415d-b91a-a289bde6d8ea}>1.7, !- Program Line 1
  SET {e87cd914-5370-42ea-b5a7-9005e5d7b625} = 29.4, !- Program Line 2
  SET {cccf0402-1ae1-4df2-8699-8680fdafc5ce} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {f5eab967-f824-415d-b91a-a289bde6d8ea}<23.9 && {f5eab967-f824-415d-b91a-a289bde6d8ea}>1.7, !- Program Line 4
  SET {e87cd914-5370-42ea-b5a7-9005e5d7b625} = 29.4, !- Program Line 5
  SET {cccf0402-1ae1-4df2-8699-8680fdafc5ce} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {f5eab967-f824-415d-b91a-a289bde6d8ea}<23.9 && {f5eab967-f824-415d-b91a-a289bde6d8ea}>1.7, !- Program Line 7
  SET {e87cd914-5370-42ea-b5a7-9005e5d7b625} = 29.4, !- Program Line 8
  SET {cccf0402-1ae1-4df2-8699-8680fdafc5ce} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {f5eab967-f824-415d-b91a-a289bde6d8ea}<23.9 && {f5eab967-f824-415d-b91a-a289bde6d8ea}>1.7, !- Program Line 10
  SET {e87cd914-5370-42ea-b5a7-9005e5d7b625} = 29.4, !- Program Line 11
  SET {cccf0402-1ae1-4df2-8699-8680fdafc5ce} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {e87cd914-5370-42ea-b5a7-9005e5d7b625} = NULL, !- Program Line 14
  SET {cccf0402-1ae1-4df2-8699-8680fdafc5ce} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

