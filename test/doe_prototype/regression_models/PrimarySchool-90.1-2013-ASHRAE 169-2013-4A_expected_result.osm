OS:EnergyManagementSystem:Program,
  {a2b23a5d-fcd6-4188-9ba2-2c01d74a8adb}, !- Handle
  ems_PVAV_OTHER_OptimumStartProg0,       !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}<23.9 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}>1.7, !- Program Line 1
  SET {e4840bd7-0386-43ab-ab8d-b4a69c693da1} = 29.4, !- Program Line 2
  SET {7c657c49-ad1c-4758-a0bd-c20d9da94352} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}<23.9 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}>1.7, !- Program Line 4
  SET {e4840bd7-0386-43ab-ab8d-b4a69c693da1} = 29.4, !- Program Line 5
  SET {7c657c49-ad1c-4758-a0bd-c20d9da94352} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}<23.9 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}>1.7, !- Program Line 7
  SET {e4840bd7-0386-43ab-ab8d-b4a69c693da1} = 29.4, !- Program Line 8
  SET {7c657c49-ad1c-4758-a0bd-c20d9da94352} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}<23.9 && {c7e1c9b4-beb2-47c2-9279-5b886883a73b}>1.7, !- Program Line 10
  SET {e4840bd7-0386-43ab-ab8d-b4a69c693da1} = 29.4, !- Program Line 11
  SET {7c657c49-ad1c-4758-a0bd-c20d9da94352} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {e4840bd7-0386-43ab-ab8d-b4a69c693da1} = NULL, !- Program Line 14
  SET {7c657c49-ad1c-4758-a0bd-c20d9da94352} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

