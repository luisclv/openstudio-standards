OS:EnergyManagementSystem:Program,
  {d407a3c1-f558-4cb2-859c-936353d6fe6f}, !- Handle
  ems_CAV_KITCHEN_OptimumStartProg0,      !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}<23.9 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}>1.7, !- Program Line 1
  SET {c396068f-53f7-47c0-bab0-2b5ca941fb6b} = 29.4, !- Program Line 2
  SET {0fe29ce2-6baa-49b8-b98d-d408480e0323} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}<23.9 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}>1.7, !- Program Line 4
  SET {c396068f-53f7-47c0-bab0-2b5ca941fb6b} = 29.4, !- Program Line 5
  SET {0fe29ce2-6baa-49b8-b98d-d408480e0323} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}<23.9 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}>1.7, !- Program Line 7
  SET {c396068f-53f7-47c0-bab0-2b5ca941fb6b} = 29.4, !- Program Line 8
  SET {0fe29ce2-6baa-49b8-b98d-d408480e0323} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}<23.9 && {bef51759-23c3-4e99-bd3b-6dbc7c111305}>1.7, !- Program Line 10
  SET {c396068f-53f7-47c0-bab0-2b5ca941fb6b} = 29.4, !- Program Line 11
  SET {0fe29ce2-6baa-49b8-b98d-d408480e0323} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {c396068f-53f7-47c0-bab0-2b5ca941fb6b} = NULL, !- Program Line 14
  SET {0fe29ce2-6baa-49b8-b98d-d408480e0323} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

