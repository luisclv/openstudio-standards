OS:EnergyManagementSystem:Program,
  {3f4c33c9-b87c-4512-8cbd-e845aabfa39a}, !- Handle
  ems_VAV_PATRMS_OptimumStartProg0,       !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}<23.9 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}>1.7, !- Program Line 1
  SET {e2f9dc71-43cd-4ad5-848a-6f814979286a} = 29.4, !- Program Line 2
  SET {eacac731-0c86-4bf1-869b-86c8942ec1bb} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}<23.9 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}>1.7, !- Program Line 4
  SET {e2f9dc71-43cd-4ad5-848a-6f814979286a} = 29.4, !- Program Line 5
  SET {eacac731-0c86-4bf1-869b-86c8942ec1bb} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}<23.9 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}>1.7, !- Program Line 7
  SET {e2f9dc71-43cd-4ad5-848a-6f814979286a} = 29.4, !- Program Line 8
  SET {eacac731-0c86-4bf1-869b-86c8942ec1bb} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}<23.9 && {796f1e18-1cca-4c1e-9d8a-6ee8fe9831d0}>1.7, !- Program Line 10
  SET {e2f9dc71-43cd-4ad5-848a-6f814979286a} = 29.4, !- Program Line 11
  SET {eacac731-0c86-4bf1-869b-86c8942ec1bb} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {e2f9dc71-43cd-4ad5-848a-6f814979286a} = NULL, !- Program Line 14
  SET {eacac731-0c86-4bf1-869b-86c8942ec1bb} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

