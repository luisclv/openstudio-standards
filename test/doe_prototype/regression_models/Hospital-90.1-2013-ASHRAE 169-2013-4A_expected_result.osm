  SET {8ede297f-2c22-450c-a216-07d69c253705} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}<23.9 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}>1.7, !- Program Line 4
  SET {cfdd002a-1d35-4168-b338-8f8c08f0ac40} = 29.4, !- Program Line 5
  SET {8ede297f-2c22-450c-a216-07d69c253705} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}<23.9 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}>1.7, !- Program Line 7
  SET {cfdd002a-1d35-4168-b338-8f8c08f0ac40} = 29.4, !- Program Line 8
  SET {8ede297f-2c22-450c-a216-07d69c253705} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}<23.9 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}>1.7, !- Program Line 10
  SET {cfdd002a-1d35-4168-b338-8f8c08f0ac40} = 29.4, !- Program Line 11
  SET {8ede297f-2c22-450c-a216-07d69c253705} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
