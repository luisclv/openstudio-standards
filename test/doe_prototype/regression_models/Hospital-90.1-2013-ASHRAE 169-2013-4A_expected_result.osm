OS:EnergyManagementSystem:Program,
  {f7c5684f-d9f6-4708-a755-7923e4570f32}, !- Handle
  ems_CAV_KITCHEN_OptimumStartProg0,      !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}<23.9 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}>1.7, !- Program Line 1
  SET {7ea46b07-c242-4c70-89cc-d9ce8d8e9f00} = 29.4, !- Program Line 2
  SET {74aceac4-3131-457a-9f27-49a93d09a8df} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}<23.9 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}>1.7, !- Program Line 4
  SET {7ea46b07-c242-4c70-89cc-d9ce8d8e9f00} = 29.4, !- Program Line 5
  SET {74aceac4-3131-457a-9f27-49a93d09a8df} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}<23.9 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}>1.7, !- Program Line 7
  SET {7ea46b07-c242-4c70-89cc-d9ce8d8e9f00} = 29.4, !- Program Line 8
  SET {74aceac4-3131-457a-9f27-49a93d09a8df} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}<23.9 && {7d40c9c8-d41f-4d68-80e7-001c67b10c22}>1.7, !- Program Line 10
  SET {7ea46b07-c242-4c70-89cc-d9ce8d8e9f00} = 29.4, !- Program Line 11
  SET {74aceac4-3131-457a-9f27-49a93d09a8df} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {7ea46b07-c242-4c70-89cc-d9ce8d8e9f00} = NULL, !- Program Line 14
  SET {74aceac4-3131-457a-9f27-49a93d09a8df} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

