  ems_VAV_PATRMS_OptimumStartProg0,       !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}<23.9 && {9ea514c4-414c-4bf4-9ce6-9719da2166fd}>1.7, !- Program Line 1
