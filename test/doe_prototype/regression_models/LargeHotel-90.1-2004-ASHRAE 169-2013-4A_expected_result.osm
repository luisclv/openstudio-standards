OS:EnergyManagementSystem:Program,
  {a770ac98-8ef5-455f-a537-6e29a0d14a61}, !- Handle
  ems_VAV_WITH_REHEAT_OptimumStartProg0,  !- Name
  IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && {2c5c6485-8444-412e-9b15-a361eb3558fb}<23.9 && {2c5c6485-8444-412e-9b15-a361eb3558fb}>1.7, !- Program Line 1
  SET {b0806d38-23b3-4d62-a9f9-43d46489c590} = 29.4, !- Program Line 2
  SET {065b27b3-e995-4f4b-80df-5c7be6ea04d0} = 15.6, !- Program Line 3
  ELSEIF DaylightSavings==0 && DayOfWeek==1 && Hour==7 && {2c5c6485-8444-412e-9b15-a361eb3558fb}<23.9 && {2c5c6485-8444-412e-9b15-a361eb3558fb}>1.7, !- Program Line 4
  SET {b0806d38-23b3-4d62-a9f9-43d46489c590} = 29.4, !- Program Line 5
  SET {065b27b3-e995-4f4b-80df-5c7be6ea04d0} = 15.6, !- Program Line 6
  ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && {2c5c6485-8444-412e-9b15-a361eb3558fb}<23.9 && {2c5c6485-8444-412e-9b15-a361eb3558fb}>1.7, !- Program Line 7
  SET {b0806d38-23b3-4d62-a9f9-43d46489c590} = 29.4, !- Program Line 8
  SET {065b27b3-e995-4f4b-80df-5c7be6ea04d0} = 15.6, !- Program Line 9
  ELSEIF DaylightSavings==1 && DayOfWeek==1 && Hour==6 && {2c5c6485-8444-412e-9b15-a361eb3558fb}<23.9 && {2c5c6485-8444-412e-9b15-a361eb3558fb}>1.7, !- Program Line 10
  SET {b0806d38-23b3-4d62-a9f9-43d46489c590} = 29.4, !- Program Line 11
  SET {065b27b3-e995-4f4b-80df-5c7be6ea04d0} = 15.6, !- Program Line 12
  ELSE,                                   !- Program Line 13
  SET {b0806d38-23b3-4d62-a9f9-43d46489c590} = NULL, !- Program Line 14
  SET {065b27b3-e995-4f4b-80df-5c7be6ea04d0} = NULL, !- Program Line 15
  ENDIF;                                  !- Program Line 16

